// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SOCIETY
  OWNER
}

enum GenderType {
  PUTRA
  PUTRI
  CAMPUR
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kosOwned   Kos[]        @relation("OwnerKos")
  bookings   Booking[]
  reviews    Review[]
}

model Kos {
  id          Int      @id @default(autoincrement())
  name        String
  address     String
  description String?
  ownerId     Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User     @relation("OwnerKos", fields: [ownerId], references: [id])
  rooms     Room[]
  facilities Facility[]
  reviews   Review[]
}

model Room {
  id        Int         @id @default(autoincrement())
  kosId     Int
  name      String
  price     Int
  gender    GenderType
  isAvailable Boolean   @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  kos       Kos       @relation(fields: [kosId], references: [id])
  bookings  Booking[]
}

model Facility {
  id      Int    @id @default(autoincrement())
  kosId   Int
  name    String

  kos     Kos    @relation(fields: [kosId], references: [id])
}

model Booking {
  id         Int           @id @default(autoincrement())
  userId     Int
  roomId     Int
  checkIn    DateTime
  duration   Int           // dalam bulan
  totalPrice Int
  status     BookingStatus @default(PENDING)
  createdAt  DateTime      @default(now())

  user   User @relation(fields: [userId], references: [id])
  room   Room @relation(fields: [roomId], references: [id])
}

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int
  kosId     Int
  rating    Int
  comment   String
  reply     String?  // balasan owner
  createdAt DateTime @default(now())

  user  User @relation(fields: [userId], references: [id])
  kos   Kos  @relation(fields: [kosId], references: [id])
}